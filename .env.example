# Sentry Configuration
# Get your DSN from: https://sentry.io/settings/{your-org}/projects/{your-project}/keys/
NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@o{org-id}.ingest.sentry.io/{project-id}
SENTRY_DSN=https://your-public-key@o{org-id}.ingest.sentry.io/{project-id}

# Sentry Auth Token for source map uploads
# Create at: https://sentry.io/settings/auth-tokens/
# Scopes needed: project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_eyJ...

# Required: Sentry organization and project (used by next.config.ts)
# Find org ID: https://sentry.io/api/0/organizations/
# Find project ID: https://sentry.io/api/0/projects/
SENTRY_ORG=o4508898012749824
SENTRY_PROJECT=4511027501727824
