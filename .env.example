# Web-Check API Konfiguration
# Diese Datei kopieren als .env und mit eigenen Werten füllen

# Google PageSpeed Insights API Key (optional, aber empfohlen)
# Holen Sie sich einen kostenlosen Key unter:
# https://developers.google.com/speed/docs/insights/v5/get-started
VITE_GOOGLE_PAGESPEED_KEY=your_google_pagespeed_api_key_here

# Shodan API Key (optional)
# Für detaillierte Server-Informationen
# https://account.shodan.io/
VITE_SHODAN_API_KEY=your_shodan_api_key_here

# CORS Proxy URL (optional)
# Für Header-Checks wenn CORS Probleme auftreten
# z.B. https://cors-anywhere.herokuapp.com/ oder eigener Proxy
VITE_CORS_PROXY=

# Eigenes Web-Check Backend (optional)
# Falls Sie das Web-Check Backend selbst hosten
VITE_WEBCHECK_API_URL=/api/web-check

# Hinweis: Diese API-Keys sind nur für den Client verfügbar
# Schützen Sie sensible Keys durch ein Backend!
